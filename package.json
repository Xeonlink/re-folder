{
  "name": "re-folder",
  "version": "1.3.1",
  "description": "Watch folder and automatic reorganize files",
  "main": "./out/main/index.js",
  "author": "Oh_jimin",
  "homepage": "https://electron-vite.org",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xeonlink/re-folder"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "yarn typecheck:node && yarn typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "yarn typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "yarn build && electron-builder build --win --publish never",
    "build:mac": "yarn build && electron-builder build --mac --publish never",
    "db:gen": "npx drizzle-kit generate --name=init"
  },
  "dependencies": {
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "4.0.0",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-context-menu": "^2.2.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tanstack/react-query": "5.96.2",
    "@tanstack/react-query-devtools": "5.96.2",
    "@tanstack/react-router": "1.168.10",
    "better-sqlite3": "12.8.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "electron-updater": "6.8.3",
    "framer-motion": "^11.11.9",
    "lucide-react": "^0.452.0",
    "openai": "^5.22.1",
    "react-color-palette": "^7.3.0",
    "react-error-boundary": "6.1.1",
    "tailwind-merge": "^2.5.3",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "3.1.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/router-plugin": "1.167.12",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "6.0.1",
    "@xeonlink/prettier-plugin-organize-attributes": "^1.1.0",
    "electron": "41.1.1",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "eslint": "10.2.0",
    "eslint-plugin-react": "7.37.5",
    "prettier": "3.8.1",
    "prettier-plugin-curly": "^0.4.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prettier-plugin-tailwindcss-canonical-classes": "^0.1.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "6.0.2",
    "vite": "8.0.7"
  }
}
